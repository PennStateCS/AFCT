# Node / Next.js build artifacts
node_modules
.next
coverage
.nyc_output
**/dist
**/build
**/.cache
**/.turbo
**/tsconfig.tsbuildinfo
**/.eslintcache

# Logs & OS/editor junk
*.log
npm-debug.log
**/.DS_Store
**/Thumbs.db
**/*.tmp
**/*.temp
*.swp
*.swo

# VCS / docs
.git
.gitignore
.github
README.md

# Docker / Compose (not needed in build context)
**/Dockerfile*
docker-compose*.yml
.dockerignore

# Env files: never bake secrets into the image (templates aren't needed in it)
.env*

# Prisma: ignore a local SQLite dev DB if present (schema + migrations stay in context)
prisma/dev.db*

# Uploads: ignore runtime data but keep placeholder so dir exists
**/public/uploads/*
!public/uploads/.gitkeep

# IDE
.vscode
.idea

# Local tooling & secrets, never bake into the image
.claude
*.key
*.crt
*.pem

# Optional: ignore tests if not needed in image
**/__tests__/**
**/*.test.*
**/*.spec.*

# Optional: package managers (if unused)
# .pnpm-store
# yarn.lock

# The docs site builds separately (github pages), never in the app image
docs-site
docs-dist
