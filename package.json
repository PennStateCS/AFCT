{
  "name": "afct",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard for the Automated Feedback for CS Theory (AFCT) system.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PennStateCS/AFCT.git"
  },
  "homepage": "https://github.com/PennStateCS/AFCT#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks',{stdio:'ignore'})}catch(e){}\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -p 3000",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings=0",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:evaluator": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/evaluator-smoke.mjs",
    "e2e": "node scripts/e2e-db.mjs && playwright test",
    "e2e:db": "node scripts/e2e-db.mjs",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report e2e-report",
    "docs:api": "node scripts/generate-openapi.mjs",
    "docs:types": "openapi-typescript docs-dist/openapi.json -o src/types/api.ts",
    "docs": "npm run docs:api && npm run docs:types",
    "postinstall": "node -e \"if(process.env.SKIP_PRISMA_GENERATE){console.log('skip prisma generate');process.exit(0)} require('child_process').execSync('prisma generate',{stdio:'inherit'})\"",
    "seed": "prisma db seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force --skip-generate",
    "db:erd": "npx prisma generate --schema=prisma/schema.prisma",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build --attach app --no-attach nginx --no-attach postgres",
    "docker:dev:detached": "docker compose -f docker-compose.dev.yml up --build -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:down:volumes": "docker compose -f docker-compose.dev.yml down -v",
    "docker:dev:clean": "docker compose -f docker-compose.dev.yml down && docker system prune -f",
    "docker:dev:nuke": "docker compose -f docker-compose.dev.yml down -v --remove-orphans",
    "docker:dev:resetdb": "docker compose -f docker-compose.dev.yml down -v",
    "docker:dev:emptydb": "docker exec -it afct-dev-postgres psql -U afct_user -d afct -c \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\" && docker exec -it afct-dev npx prisma migrate deploy",
    "docker:dev:migrate": "docker exec -it afct-dev npx prisma migrate dev",
    "docker:dev:migrate:deploy": "docker exec afct-dev npx prisma migrate deploy",
    "docker:dev:generate": "docker exec -it afct-dev npx prisma generate",
    "docker:dev:studio": "docker exec -it afct-dev npx prisma studio",
    "docker:dev:seed": "docker exec -it afct-dev npx prisma db seed",
    "docker:dev:psql": "docker exec -it afct-dev-postgres psql -U afct_user -d afct",
    "docker:prod": "docker compose up --build -d",
    "docker:prod:nobuild": "docker compose up -d",
    "docker:prod:down": "docker compose down",
    "docker:prod:clean": "docker compose down && docker system prune -f",
    "docker:prod:restart": "npm run docker:prod:down && npm run docker:prod:nobuild",
    "docker:prod:ps": "docker compose ps",
    "docker:prod:logs": "docker compose logs -f",
    "docker:prod:logs:app": "docker compose logs -f app",
    "docker:prod:logs:db": "docker compose logs -f postgres",
    "docker:prod:logs:nginx": "docker compose logs -f nginx",
    "docker:prod:logs:backup": "docker compose logs -f db-backup",
    "docker:prod:exec:app": "docker compose exec app sh",
    "docker:prod:exec:db": "docker compose exec postgres psql -U afct_user -d afct",
    "docker:prod:migrate": "docker compose exec app npx prisma migrate deploy",
    "docker:prod:seed": "docker compose exec app npx prisma db seed"
  },
  "dependencies": {
    "@auth/core": "0.40.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@viz-js/viz": "^3.28.0",
    "@xyflow/react": "^12.11.2",
    "acme-client": "^5.4.0",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^10.1.0",
    "cytoscape": "^3.34.0",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-svg": "^0.4.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "elkjs": "^0.10.2",
    "fast-xml-parser": "^5.9.3",
    "framer-motion": "^12.42.2",
    "html-to-image": "^1.11.13",
    "input-otp": "^1.4.2",
    "json-2-csv": "^5.5.11",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^4.12.2",
    "react-spinners": "^0.17.0",
    "sonner": "^2.0.7",
    "sql-formatter": "^15.8.2",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tippy.js": "^6.3.7",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@playwright/test": "^1.61.1",
    "@seriousme/openapi-schema-validator": "^2.9.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/viz.js": "^2.1.5",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.17",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma-erd-generator": "^2.4.3",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@auth/core": "0.40.0",
    "next-auth": {
      "@auth/core": "0.40.0"
    },
    "@auth/prisma-adapter": {
      "@auth/core": "0.40.0"
    }
  }
}
