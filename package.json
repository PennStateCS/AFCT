{
  "name": "afct",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "cross-env NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "ts-node prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:generate:prod": "prisma generate --schema=prisma/schema.production.prisma",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy --schema=prisma/schema.production.prisma",
    "db:studio": "prisma studio",
    "db:studio:prod": "prisma studio --schema=prisma/schema.production.prisma",
    "deploy:prod": "node scripts/deploy-production.js",
    "postinstall": "npm run db:generate:safe",
    "db:generate:safe": "prisma generate || npm run db:generate:fallback",
    "db:generate:fallback": "echo 'ERD generation failed (missing Chrome/Chromium), continuing without ERD...' && prisma generate --schema=prisma/schema.production.prisma || echo 'Prisma client generated successfully without ERD'",
    "db:generate:with-erd": "cp prisma/schema.development.prisma prisma/schema.prisma && prisma generate && echo 'ERD generated successfully at ERD.svg'",
    "db:install-chrome": "echo 'To enable ERD generation, install Chrome/Chromium: sudo apt install chromium-browser (Ubuntu) or download Chrome manually, then run: npm run db:generate:with-erd'",
    "db:test": "node scripts/test-db.js",
    "db:test:prod": "node scripts/test-db.js .env.production",
    "db:reset:prod": "echo 'Use setup wizard option 11 for safe production reset'"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.12.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-form": "^0.1.7",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "@types/pg": "^8.15.5",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.6",
    "input-otp": "^1.4.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.536.0",
    "next": "^15.4.6",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "prisma": "^6.12.0",
    "react": "^19.1.1",
    "react-day-picker": "^9.8.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "sonner": "^2.0.6",
    "sql-formatter": "^15.6.6",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@mermaid-js/mermaid-cli": "^11.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.2.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.4.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma-erd-generator": "^2.0.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
