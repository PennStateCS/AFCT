{
  "name": "afct",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings=0",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node -e \"if(process.env.SKIP_PRISMA_GENERATE){console.log('skip prisma generate');process.exit(0)} require('child_process').execSync('prisma generate',{stdio:'inherit'})\"",
    "seed": "prisma db seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force --skip-generate",
    "db:erd": "npx prisma generate --schema=prisma/schema.prisma",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build --attach app --no-attach nginx --no-attach postgres",
    "docker:dev:detached": "docker compose -f docker-compose.dev.yml up --build -d",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down && docker system prune -f",
    "docker:down:volumes": "docker compose -f docker-compose.dev.yml down -v",
    "docker:nuke": "docker compose -f docker-compose.dev.yml down -v && docker system prune -af --volumes",
    "docker:studio": "docker exec -it afct-dev npx prisma studio",
    "docker:seed": "docker exec -it afct-dev npx prisma db seed",
    "docker:psql": "docker exec -it afct-dev-postgres psql -U afct_user -d afct",
    "docker:dev:migrate": "docker exec -it afct-dev npx prisma migrate dev",
    "docker:dev:generate": "docker exec -it afct-dev npx prisma generate",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:clean": "docker compose -f docker-compose.dev.yml down && docker system prune -f",
    "docker:dev:down:volumes": "npm run docker:down:volumes",
    "docker:dev:emptydb": "docker exec -it afct-dev-postgres psql -U afct_user -d afct -c \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\" && docker exec -it afct-dev npx prisma migrate deploy",
    "docker:dev:nuke": "npm run docker:nuke",
    "docker:dev:resetdb": "npm run docker:down:volumes",
    "docker:dev:studio": "npm run docker:studio",
    "docker:dev:seed": "npm run docker:seed",
    "docker:dev:psql": "npm run docker:psql",
    "docker:prod": "docker compose up --build -d",
    "docker:prod:nobuild": "docker compose up -d",
    "docker:prod:down": "docker compose down",
    "docker:prod:restart": "npm run docker:prod:down && npm run docker:prod:nobuild",
    "docker:prod:ps": "docker compose ps",
    "docker:prod:logs": "docker compose logs -f",
    "docker:prod:logs:app": "docker compose logs -f app",
    "docker:prod:logs:db": "docker compose logs -f postgres",
    "docker:prod:logs:nginx": "docker compose logs -f nginx",
    "docker:prod:logs:backup": "docker compose logs -f db-backup",
    "docker:prod:exec:app": "docker compose exec app sh",
    "docker:prod:exec:db": "docker compose exec postgres psql -U afct_user -d afct",
    "docker:prod:migrate": "docker compose exec app npx prisma migrate deploy",
    "docker:prod:seed": "docker compose exec app npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/core": "0.40.0",
    "@auth/prisma-adapter": "^2.10.0",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@viz-js/viz": "^3.0.0",
    "@xyflow/react": "^12.8.4",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "cytoscape": "^3.33.1",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-svg": "^0.4.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^10.0.0",
    "elkjs": "^0.10.0",
    "fast-xml-parser": "^5.4.1",
    "framer-motion": "^12.23.12",
    "html-to-image": "^1.11.13",
    "input-otp": "^1.4.2",
    "json-2-csv": "^5.5.11",
    "lucide-react": "^0.469.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.29",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "prisma": "^6.14.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.8.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.62.0",
    "sonner": "^1.7.4",
    "sql-formatter": "^15.6.6",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.3.1",
    "tippy.js": "^6.3.7",
    "tsx": "^4.20.4",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.15.5",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/viz.js": "^2.1.5",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.13.0",
    "eslint-config-next": "15.4.1",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma-erd-generator": "^2.4.2",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@auth/core": "0.40.0",
    "next-auth": {
      "@auth/core": "0.40.0"
    },
    "@auth/prisma-adapter": {
      "@auth/core": "0.40.0"
    }
  }
}
