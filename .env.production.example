
# Production Environment Configuration
# AFCT Dashboard - Docker Production Setup

# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.production.example .env.production
# 2. Update all values with your production secrets and domain
# 3. .env.production is ignored by git - keep secrets here safe
# 4. SECURITY: Use strong passwords and rotate secrets regularly

# Node Environment
NODE_ENV="production"

# Application Metadata
APP_NAME="AFCT Dashboard"
APP_VERSION="1.0.0"

# Database Configuration
POSTGRES_PASSWORD="your_secure_postgres_password_here"
DATABASE_URL="postgresql://afct_user:${POSTGRES_PASSWORD}@postgres:5432/afct"
DB_HOST="postgres"
DB_PORT="5432"
DB_USER="afct_user"
DB_NAME="afct"

# Database Startup Configuration
WAIT_FOR_DB="true"
DB_WAIT_SECONDS="60"
ENSURE_PRISMA_CLIENT="true"
MIGRATE_ON_START="true"
SEED_ON_START="auto"                # SEED_ON_START: auto = seed only in production, true = always, false = never

# Admin Account Configuration (required for production seed)
# These credentials create the initial admin user on first database setup
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="your_secure_admin_password_here"
DEFAULT_ADMIN_FIRST_NAME="Admin"
DEFAULT_ADMIN_LAST_NAME="User"

# Authentication Configuration
NEXTAUTH_SECRET="your_long_random_nextauth_secret_here"
NEXTAUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"

# Captcha Configuration
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="your_hcaptcha_site_key"
HCAPTCHA_SECRET_KEY="your_hcaptcha_secret_key"

# Java/JAR Configuration
CFGANALYZER_LIMIT="15"
CFGANALYZER_BINARY="/app/bin/cfganalyzer"

# Submission Queue / Evaluator Configuration (optional; defaults shown)
# Max wall-clock time (ms) a single evaluation may run before it is killed.
SUBMISSION_EVAL_TIMEOUT_MS="30000"
# Max JVM heap (MB) for the evaluator process.
SUBMISSION_EVAL_MAX_MEMORY_MB="256"
# Min time (ms) a student must wait between submissions to the same problem.
SUBMISSION_RESUBMIT_COOLDOWN_MS="10000"

# File Upload Configuration
MAX_FILE_SIZE="10485760"
