FROM node:18-alpine
WORKDIR /app

# Install Java (OpenJDK) for running .jar files
RUN apk add --no-cache openjdk21-jre

COPY package*.json ./
RUN npm install

COPY . .
RUN npx prisma generate

# Conditionally make CFG analyzer binary executable if present in the repo
RUN mkdir -p /app/bin && if [ -f bin/cfganalyzer ]; then chmod +x bin/cfganalyzer; fi || true

# Copy jars directory into image (place your .jar files in repo `jars/`)
COPY jars /app/jars
RUN chmod -R 644 /app/jars || true && chmod +x /app/jars/*.jar || true

# Verify Java installation
RUN java -version

EXPOSE 3000
CMD ["npm", "run", "dev"]
