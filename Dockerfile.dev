# syntax=docker/dockerfile:1.7
FROM node:20-bullseye-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl \
    python3 \
    make \
    g++ \
    git \
    openjdk-17-jre-headless \
    tini \
    netcat-openbsd \
    postgresql-client \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Environment variables
ENV NODE_ENV=development
ENV DISABLE_ERD=true
ENV NEXT_TELEMETRY_DISABLED=1
ENV PATH="/app/bin:${PATH}"

WORKDIR /app

# Ensure app directory is writable by node user
RUN chown -R node:node /app

# Private upload directories - create as root to ensure they exist
RUN mkdir -p /private/uploads/pfps \
    /private/uploads/problems \
    /private/uploads/solutions \
    /private/uploads/submissions && \
    chmod -R 775 /private/uploads

# Declare upload volumes for persistence
VOLUME ["/private/uploads", "/app/public/uploads"]

# Dependencies
COPY --chown=node:node package.json package-lock.json ./
RUN --mount=type=cache,id=npm-cache-node20,target=/home/node/.npm,uid=1000,gid=1000 \
    npm ci --prefer-offline --no-audit --progress=false

# Tooling
COPY --chown=node:node jars /app/jars
COPY --chown=node:node bin  /app/bin
RUN if [ -f /app/bin/cfganalyzer ]; then chmod +x /app/bin/cfganalyzer; fi

# App source
COPY --chown=node:node . .

# Prisma
RUN --mount=type=cache,id=prisma-cache-node20,target=/home/node/.cache/prisma,uid=1000,gid=1000 \
    npx prisma generate

# Verify Java installation
RUN java -version || true

# Entrypoint
COPY --chown=node:node entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

# Switch to non-root user
USER node

EXPOSE 3000
EXPOSE 5555

ENTRYPOINT ["/usr/bin/tini","-g","--","/bin/sh","./entrypoint.sh"]
# CMD supplied by docker-compose