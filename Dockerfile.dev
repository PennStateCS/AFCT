FROM node:18-alpine
WORKDIR /app

# Install Java (OpenJDK) for running .jar files - moved earlier for better caching
RUN apk add --no-cache openjdk21-jre

# Copy package files first for better Docker layer caching
COPY package*.json ./

# Install dependencies (this layer will be cached unless package.json changes)
RUN npm ci --prefer-offline --no-audit --progress=false

# Create directories early
RUN mkdir -p /app/bin /app/jars

# Copy and setup binaries/jars (these change less frequently)
COPY jars /app/jars
COPY bin /app/bin
RUN chmod -R 644 /app/jars || true && chmod +x /app/jars/*.jar || true
RUN if [ -f bin/cfganalyzer ]; then chmod +x bin/cfganalyzer; fi || true

# Copy source code (this layer rebuilds when code changes)
COPY . .

# Generate Prisma client (only when schema changes)
RUN npx prisma generate

# Verify Java installation (non-fatal)
RUN java -version || echo "Java check completed"

EXPOSE 3000
CMD ["npm", "run", "dev:turbo"]
