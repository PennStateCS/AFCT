# AFCT Dashboard Environment Configuration Template
# Copy this file to .env.local for local development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Development Database (SQLite)
DATABASE_URL="file:./dev.db"

# Production Database (PostgreSQL) - Configure for production deployment
# DATABASE_URL="postgresql://username:password@localhost:5432/afct_production"

# Alternative PostgreSQL URL format
# POSTGRES_URL="postgresql://username:password@localhost:5432/afct_production"

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT Secret - CHANGE THIS for production!
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Upload directory (relative to project root)
UPLOAD_DIR="./public/uploads"

# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE="10485760"

# Allowed file extensions (comma-separated)
ALLOWED_FILE_TYPES="pdf,doc,docx,txt,jpg,jpeg,png,gif,zip"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application metadata
APP_NAME="AFCT Dashboard"
APP_VERSION="1.0.0"
APP_URL="http://localhost:3000"

# Admin contact
ADMIN_EMAIL="admin@example.com"

# =============================================================================
# OPTIONAL: EMAIL CONFIGURATION
# =============================================================================

# SMTP settings for email notifications (optional)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""

# =============================================================================
# OPTIONAL: EXTERNAL SERVICES
# =============================================================================

# API keys for external services (if needed)
# EXTERNAL_API_KEY=""
# ANALYTICS_ID=""

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Next.js settings
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Debug settings
# DEBUG="prisma:query"
# LOG_LEVEL="info"

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# CORS origins (comma-separated for multiple origins)
# CORS_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Session settings
# SESSION_TIMEOUT="24h"

# Rate limiting
# RATE_LIMIT_WINDOW="15m"
# RATE_LIMIT_MAX="100"
