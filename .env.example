# AFCT Dashboard Environment Configuration Template
# Copy this file to .env for development or .env.production for production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Docker Development Database (PostgreSQL)
DATABASE_URL="postgresql://afct_user:afct_password@db:5432/afct_dev"

# Docker Production Database (PostgreSQL)
# DATABASE_URL="postgresql://afct_user:secure_password@db:5432/afct_prod"

# Local Development (non-Docker) - Alternative
# DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# =============================================================================
# AUTHENTICATION
# =============================================================================

# NextAuth Secret - REQUIRED for NextAuth v5
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-change-this-in-production"

# NextAuth URL - Update for production domain
NEXTAUTH_URL="http://localhost:3000"

# JWT Secret - CHANGE THIS for production!
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-key-change-this-in-production"

# =============================================================================
# JAVA/JAR CONFIGURATION
# =============================================================================

# CFG Analyzer limit for code analysis
CFGANALYZER_LIMIT="15"

# CFG Analyzer binary path (Docker container path)
CFGANALYZER_BINARY="/app/bin/cfganalyzer"

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Upload directory (relative to project root)
UPLOAD_DIR="./public/uploads"

# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE="10485760"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Node environment
NODE_ENV="development"

# Application metadata
APP_NAME="AFCT Dashboard"
APP_VERSION="1.0.0"

# =============================================================================
# DOCKER ENVIRONMENT EXAMPLES
# =============================================================================

# Development Environment (.env.development):
# DATABASE_URL="postgresql://afct_user:afct_password@db:5432/afct_dev"
# NEXTAUTH_URL="http://localhost:3000"
# NODE_ENV="development"

# Production Environment (.env.production):
# DATABASE_URL="postgresql://afct_user:secure_password@db:5432/afct_prod"
# NEXTAUTH_URL="https://your-domain.com"
# NODE_ENV="production"

# =============================================================================
# INSTRUCTIONS
# =============================================================================

# 1. Copy this file to .env for development
# 2. Update the DATABASE_URL with your credentials
# 3. Generate secure secrets for NEXTAUTH_SECRET and JWT_SECRET
# 4. Add your CFG analyzer binary to bin/cfganalyzer directory
# 5. For production, copy to .env.production and update values
