# Development image for the AFCT dashboard.
#
# Single stage. The app source is bind-mounted at runtime (see docker-compose.dev),
# so this image only provides the toolchain, installed deps, and Java runtime that
# hot reload needs. Also used by the prisma-studio service.
# Base images are pinned by digest (tag kept for readability). Bump deliberately.
FROM node:22-bookworm-slim@sha256:53ada149d435c38b14476cb57e4a7da73c15595aba79bd6971b547ceb6d018bf
WORKDIR /app

# python3/make/g++ build native modules (bcrypt); postgres-client + netcat back
# the DB wait in the entrypoint; tini is PID 1; curl is handy for debugging.
# fontconfig + a base font are required by the Java evaluator: JFLAP's Universe
# class initializes Swing (a JFileChooser) even in CLI mode, which needs font
# metrics — without them the JRE throws "Fontconfig head is null".
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ git tini netcat-openbsd postgresql-client openssl ca-certificates curl \
    fontconfig fonts-dejavu-core

# Java 21 runtime, copied from the official image (pinned, no network fetch).
# Runs jars/afct-evaluator.jar when grading submissions.
ENV JAVA_HOME=/opt/java/openjdk
ENV PATH="${JAVA_HOME}/bin:${PATH}"
COPY --from=eclipse-temurin:21-jre@sha256:d2b9f8f12212cadcfdf889461531784e8fd097feade954d65b31ee7a71c473ec /opt/java/openjdk /opt/java/openjdk

ENV NODE_ENV=development
ENV DISABLE_ERD=true
ENV NEXT_TELEMETRY_DISABLED=1
# ERD is disabled, so skip puppeteer's ~150MB Chromium download during npm ci.
ENV PUPPETEER_SKIP_DOWNLOAD=1
# Put the app's own bin dir (cfganalyzer) on PATH.
ENV PATH="/app/bin:${PATH}"

# Upload dirs (backed by named volumes in compose).
RUN mkdir -p /private/uploads/pfps /private/uploads/problems \
             /private/uploads/solutions /private/uploads/submissions && \
    chmod -R 775 /private/uploads

# Install deps first so source edits don't re-run npm ci. Skip the postinstall
# `prisma generate` here — the schema isn't copied yet; the client is generated
# below, after the source is in place.
COPY --chown=node:node package.json package-lock.json ./
RUN SKIP_PRISMA_GENERATE=1 npm ci --legacy-peer-deps --prefer-offline --no-audit --progress=false

# Evaluator JAR + the cfganalyzer binary it shells out to.
COPY --chown=node:node jars /app/jars
COPY --chown=node:node bin /app/bin
RUN if [ -f /app/bin/cfganalyzer ]; then chmod +x /app/bin/cfganalyzer; fi

# Baked-in source. The dev bind mount overlays this; it exists so the image also
# works on its own (e.g. the prisma-studio service).
COPY --chown=node:node . .
RUN npx prisma generate

# Fail the build now if the copied JRE can't run.
RUN java -version

COPY --chown=node:node docker/entrypoint.sh ./docker/entrypoint.sh
RUN chmod +x ./docker/entrypoint.sh

USER node
EXPOSE 3000
EXPOSE 5555

ENTRYPOINT ["/usr/bin/tini", "-g", "--", "/bin/sh", "./docker/entrypoint.sh"]
# CMD comes from docker-compose (npm run dev, or prisma studio).
