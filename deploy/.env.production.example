# AFCT Dashboard: production configuration.
#
# You normally do NOT edit this by hand: run `sh install.sh`, which generates
# .env.production for you (strong random secrets + your admin details).
#
# Advanced/manual setup: copy this file to `.env.production`, fill every value,
# and run `docker compose up -d`. Keep .env.production secret (chmod 600).

NODE_ENV=production

# --- Database ---------------------------------------------------------------
# Use a long random password. DATABASE_URL must embed the same password.
POSTGRES_PASSWORD=change_me_to_a_long_random_string
DATABASE_URL=postgresql://afct_user:change_me_to_a_long_random_string@postgres:5432/afct

# --- Initial admin (seeded on the first run, on an empty database) -----------
ADMIN_EMAIL=admin@your-domain.edu
ADMIN_PASSWORD=change_me_to_a_strong_password

# --- Authentication ---------------------------------------------------------
# NEXTAUTH_SECRET must be a long random string (e.g. `openssl rand -base64 40`).
NEXTAUTH_SECRET=change_me_to_a_long_random_string
# The public URL people use to reach the site.
NEXTAUTH_URL=https://your-domain.edu
AUTH_TRUST_HOST=true

# --- Optional: deployed app version -----------------------------------------
# Selects the AFCT application image tag. Leave unset to track `main` (the latest
# stable build). The in-app updater manages this line when you upgrade from the
# admin interface; set it by hand only to pin a specific released version.
# AFCT_APP_TAG=main

# --- Optional: hCaptcha -----------------------------------------------------
# Fallbacks only; these can also be set later in Admin -> System Settings.
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET_KEY=

# --- Optional: evaluator / submission tuning --------------------------------
# All of these are fallbacks; the live values come from System Settings once set.
# SUBMISSION_EVAL_TIMEOUT_MS=30000
# SUBMISSION_EVAL_MAX_MEMORY_MB=256
# SUBMISSION_MAX_CONCURRENT=5
# LOGIN_MAX_ATTEMPTS=10
# LOGIN_LOCKOUT_MINUTES=45
