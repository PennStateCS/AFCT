# Node.js
node_modules/

# Environment files (ignore actual secrets, keep templates only)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.production.local
!.env.development.example
!.env.production.example

# Next.js build outputs
.next/
out/
build/

# Docker
docker-compose.override.yml
.docker/

# Database (PostgreSQL volumes and data)
postgres-data/
db-data/
*.sql
!prisma/migrations/**/*.sql
*.dump

# Yarn / pnpm / npm logs
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel deployment
.vercel/

# Prisma
src/generated/prisma
prisma/ERD.svg

# Testing
coverage/

# OS files
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo
next-env.d.ts

# SSL keys (never commit these)
*.pem

# IDE settings
.vscode/
.idea/
*.sw?

# Claude Code
.claude/

# Uploads and user content
public/uploads/*
!public/uploads/.gitkeep
private/uploads/*
!private/uploads/.gitkeep

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
.cache/
