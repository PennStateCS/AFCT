generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CourseRole {
  FACULTY
  TA
  STUDENT
}

enum ProblemType {
  PDA
  RE
  CFG
  FA
  TM
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// How the empty string is rendered in automata/languages for a course.
enum EmptyStringNotation {
  EPSILON // ε
  LAMBDA // λ
}

// Severity/level of an audit-log entry.
enum LogSeverity {
  INFO // routine, successful activity
  WARNING // expected rejections / invalid input / non-fatal issues
  ERROR // system or operational failures
  SECURITY // auth failures and access-control denials
}

// Who an AssignmentOverride targets. Only STUDENT ships now; GROUP is reserved for the
// Group Sets rework (see AssignmentOverride).
enum OverrideTargetType {
  STUDENT // userId set, groupId null
  GROUP // groupId set, userId null (reserved)
}

model User {
  id                String  @id @default(cuid())
  email             String  @unique
  firstName         String?
  lastName          String?
  password          String
  temporaryPassword Boolean @default(false)
  // Global system-admin grant. Course-level abilities live on Roster.role; this
  // flag is the only global privilege.
  isAdmin           Boolean @default(false)
  avatar            String?
  // Avatar framing (0..1 for x/y, zoom multiplier). The original image is stored and
  // these are applied as a CSS transform at render, so re-cropping needs no re-upload.
  // Nullable to match the existing columns (migration 20260713155236_avatar_info);
  // callers fall back to 0.5/0.5/1 when null.
  cropX             Float?
  cropY             Float?
  zoom              Float?
  timezone          String?
  inactive          Boolean @default(false)

  // Stamped on every password change/reset. A JWT issued before this instant is
  // rejected in the session callback, so a reset actually terminates existing
  // sessions (e.g. an attacker's) rather than leaving them valid until expiry.
  passwordChangedAt DateTime?

  // Last successful sign-in. Stored (not derived from ActivityLog) so it survives
  // log purges; stamped in the NextAuth signIn event.
  lastLogin DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rosterEntries       Roster[]
  submissions         Submission[]
  problemGrades       AssignmentProblemGrade[]
  activityLogs        ActivityLog[]
  commentsAbout       Comment[]                @relation("CommentsAboutStudent") // Comments about this student's work
  commentsAuthored    Comment[]                @relation("CommentAuthor") // Comments this user wrote
  clientTokens        ClientApiToken[] // Bearer tokens issued to the native (Java) client
  assignmentAssignees AssignmentAssignee[]     @relation("AssigneeTarget") // assignments this student is individually assigned
  assignmentOverrides AssignmentOverride[]     @relation("OverrideTarget") // deadline overrides targeting this student
  overridesCreated    AssignmentOverride[]     @relation("OverrideCreatedBy") // overrides this user created

  @@index([isAdmin])
  @@index([inactive])
  @@index([createdAt])
}

// Bearer token for the native submission client (the Java app). Cookie/NextAuth is
// for the browser; native clients authenticate with one of these instead. Only the
// SHA-256 hash of the token is stored; the plaintext is shown once at issue time.
// Tokens are revocable (revokedAt) and expire (expiresAt), so a lost device or a
// stale client can be cut off without touching the user's password.
model ClientApiToken {
  id        String @id @default(cuid())
  tokenHash String @unique // sha256(token), never the plaintext

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Optional client-supplied device label, for the user/admin to tell tokens apart.
  label String?

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  @@index([userId])
}

model Course {
  id                  String    @id @default(cuid())
  name                String
  code                String
  regCode             String?   @unique
  semester            String
  credits             Int
  startDate           DateTime
  endDate             DateTime
  registrationOpenAt  DateTime?
  registrationCloseAt DateTime?
  isPublished         Boolean   @default(false)
  isArchived          Boolean   @default(false)

  // Soft delete: when set, the course is retained for recovery but hidden from all
  // non-admin views and inaccessible through the app. Deletion requires the course to
  // already be archived, so a deleted course is always archived too.
  deletedAt DateTime?

  // The canonical IANA timezone that anchors this course's deadlines. Staff-entered
  // wall-times (due dates, late cutoffs) are interpreted in this zone and stored as
  // UTC, so a deadline means the same instant for every student. Defaults to the
  // system timezone at creation.
  timezone String @default("UTC")

  // How the empty string is displayed in automata/languages for this course.
  emptyStringNotation EmptyStringNotation @default(EPSILON)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roster       Roster[] // Users in the course with roles
  assignments  Assignment[]
  problems     Problem[]
  submissions  Submission[]
  groupSets    GroupSet[]
  activityLogs ActivityLog[]

  @@index([isPublished])
  @@index([createdAt])
  @@index([registrationOpenAt])
  @@index([registrationCloseAt])
  @@index([deletedAt])
}

model Roster {
  id   String     @id @default(cuid())
  role CourseRole

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments         Comment[]
  groupMemberships GroupMembership[]

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([role])
}

model Assignment {
  id                 String    @id @default(cuid())
  title              String
  description        String?
  dueDate            DateTime
  // "Available from" for the whole class. Null means available immediately. Per-student
  // extensions can override this via AssignmentOverride; the effective value is resolved
  // in lib/effective-deadline. Interpreted in the course timezone like dueDate.
  unlockAt           DateTime?
  // When true the assignment is assigned to everyone (every student for an individual
  // assignment; every group in the set for a group assignment). When false it is assigned
  // only to the targets named in AssignmentAssignee. A student is "assigned" iff
  // assignedToEveryone OR an assignee row names them / a group they belong to. See
  // lib/assignment-visibility for the single definition.
  assignedToEveryone Boolean   @default(true)
  isPublished        Boolean   @default(false)

  // Individual vs group is the single fact groupSetId carries: null = individual
  // assignment; set = group assignment tied to that one group set (students are assigned
  // via their group in the set and submit as a group). No mixing sets on one assignment.
  // The Individual/Group label shown on the course page is derived from this, not stored.
  groupSet   GroupSet? @relation(fields: [groupSetId], references: [id], onDelete: SetNull)
  groupSetId String?

  // Late submission controls. Defaults to false to match the app (the create form
  // and API both default this off; the value is always sent explicitly).
  allowLateSubmissions Boolean   @default(false)
  lateCutoff           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  problems     AssignmentProblem[]
  comments     Comment[]
  activityLogs ActivityLog[]
  assignees    AssignmentAssignee[]
  overrides    AssignmentOverride[]

  @@index([courseId])
  @@index([isPublished])
  @@index([dueDate])
  @@index([lateCutoff])
  @@index([courseId, isPublished])
  @@index([groupSetId])
}

// Assignment audience membership (Canvas "assign to specific students / groups"). Rows
// exist only when Assignment.assignedToEveryone is false; each names one assigned STUDENT
// or one assigned GROUP (a StudentGroup in the assignment's group set). Rows carry NO
// dates -- date/late exceptions are AssignmentOverride rows, an independent concern, so
// changing who is assigned and changing someone's dates never interfere. A student is
// "assigned" iff assignedToEveryone, a STUDENT row names them, or a GROUP row names a
// group they belong to (lib/assignment-visibility).
model AssignmentAssignee {
  id         String             @id @default(cuid())
  targetType OverrideTargetType

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String

  user   User?   @relation("AssigneeTarget", fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  studentGroup StudentGroup? @relation("AssigneeGroupTarget", fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, userId]) // at most one assignee row per (assignment, student)
  @@unique([assignmentId, groupId]) // at most one per (assignment, group)
  @@index([userId])
  @@index([groupId])
}

// A per-target date/late EXCEPTION for one assignment (Canvas "Assign To" dates). This is
// strictly about WHEN, never WHO: membership lives in AssignmentAssignee. A row supersedes
// the assignment's base dueDate/unlockAt/lateCutoff/allowLateSubmissions for one target;
// every field is nullable and null means "inherit the assignment's value", so an override
// can move only the due date and keep the base late policy. At least one field must be
// set (a no-op override is meaningless -- enforced by the AssignmentOverride_has_change
// CHECK). Resolution + the inherit rule live in lib/effective-deadline.
//
// A target is either a STUDENT (userId set) or a GROUP (groupId set, a StudentGroup within
// the assignment's groupSet); it must already be assigned (validated on write).
model AssignmentOverride {
  id         String             @id @default(cuid())
  targetType OverrideTargetType

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String

  user    User?   @relation("OverrideTarget", fields: [userId], references: [id], onDelete: Cascade)
  userId  String?

  // GROUP target: the StudentGroup this override applies to (all its members).
  studentGroup StudentGroup? @relation("OverrideGroupTarget", fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String?

  unlockAt             DateTime?
  dueDate              DateTime?
  lateCutoff           DateTime?
  allowLateSubmissions Boolean?

  // Nullable + SetNull so deleting the staff account that created an override does not
  // block user deletion (same pattern as ActivityLog). The durable actor identity is in
  // the activity log, not this column.
  createdBy   User?    @relation("OverrideCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([assignmentId, userId]) // at most one override per (assignment, student)
  @@unique([assignmentId, groupId]) // future: at most one per (assignment, group)
  @@index([userId])
  @@index([groupId])
}

model Problem {
  id                String       @id @default(cuid())
  title             String
  description       String?
  fileName          String?
  originalFileName  String?
  type              ProblemType?
  // FA/PDA state cap and FA determinism are intrinsic to the problem definition.
  maxStates         Int?
  isDeterministic   Boolean?
  // NOTE: maxPoints / maxSubmissions / autograderEnabled are per-assignment and live on
  // AssignmentProblem (a problem can be worth different points, allow a different number
  // of submissions, or be autograded in one assignment but not another). They are NOT here.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  assignments  AssignmentProblem[]
  comments     Comment[]
  activityLogs ActivityLog[]

  @@index([courseId])
  @@index([type])
  @@index([createdAt])
}

model AssignmentProblem {
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  problem      Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId    String

  // Per-assignment configuration
  maxPoints         Float   @default(0)
  maxSubmissions    Int     @default(1)
  autograderEnabled Boolean @default(true)

  submissions Submission[]
  grades      AssignmentProblemGrade[]

  @@id([assignmentId, problemId])
  @@index([assignmentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Group Sets. A course has many group sets; a group set has many groups; a group
// has many student members. A student belongs to at most one group within a given
// set, but may belong to groups in different sets. Assignments can target groups in
// a set (see Assignment.groupSetId) for group submissions.
// ─────────────────────────────────────────────────────────────────────────────

model GroupSet {
  id   String @id @default(cuid())
  name String

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Sticky lock: stamped the first time a submission or grade is created for an
  // assignment using this set, and never cleared. Once set, the set's groups and
  // memberships are frozen (renaming and duplication stay allowed) so changing them
  // can't retroactively alter academic records. Read via lib/group-set-service.
  lockedAt DateTime?

  groups      StudentGroup[]
  assignments Assignment[]

  // Unique set name per course. Case-insensitive + trimmed uniqueness is enforced
  // in the service layer (this DB constraint is the exact-match backstop).
  @@unique([courseId, name])
  @@index([courseId])
}

model StudentGroup {
  id   String @id @default(cuid())
  name String

  groupSet   GroupSet @relation(fields: [groupSetId], references: [id], onDelete: Cascade)
  groupSetId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         GroupMembership[]
  assignmentAssignees AssignmentAssignee[] @relation("AssigneeGroupTarget")
  assignmentOverrides AssignmentOverride[] @relation("OverrideGroupTarget")
  submissions         Submission[]

  // Unique group name within its set (case-insensitive + trimmed in the service
  // layer). Different sets may reuse the same group names.
  @@unique([groupSetId, name])
  // Composite target so a membership can prove its group belongs to its set at
  // the database level.
  @@unique([id, groupSetId])
  @@index([groupSetId])
}

model GroupMembership {
  id String @id @default(cuid())

  groupSetId String

  // The group is bound to its set through a composite reference, so the database
  // rejects any membership whose group lives in a different set.
  group   StudentGroup @relation(fields: [groupId, groupSetId], references: [id, groupSetId], onDelete: Cascade)
  groupId String

  // The member must be a roster row in the course (the service layer always sets
  // courseId from the set, and additionally requires role STUDENT + active). This
  // composite reference to Roster is the database-level "is enrolled here" guard.
  roster   Roster @relation(fields: [courseId, userId], references: [courseId, userId], onDelete: Cascade)
  courseId String
  userId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The concurrency-critical guarantee: a student can hold at most one group per
  // set even under two simultaneous assign requests.
  @@unique([groupSetId, userId])
  @@index([groupId, groupSetId])
  @@index([courseId, userId])
  @@index([userId])
}

model Submission {
  id            String   @id @default(cuid())
  feedback      String?
  correct       Boolean?
  evaluationRaw Json?

  fileName         String?
  originalFileName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignmentProblem AssignmentProblem @relation(fields: [assignmentId, problemId], references: [assignmentId, problemId], onDelete: Cascade)

  assignmentId String
  problemId    String

  // For individual submissions this is the submitting student
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  // Course reference
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  // Set for a group submission: the StudentGroup that owns this submission set. Any
  // member's submit writes the group here; individual submissions leave it null. The
  // submitting member is still recorded in studentId.
  studentGroup   StudentGroup? @relation(fields: [studentGroupId], references: [id], onDelete: SetNull)
  studentGroupId String?

  // Queue
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime         @default(now())
  attempts    Int              @default(0) // Number of times the worker has claimed this submission

  // Logs
  activityLogs ActivityLog[]

  @@index([assignmentId])
  @@index([studentId])
  @@index([courseId])
  @@index([studentGroupId])
  @@index([assignmentId, problemId, studentId])
  // Group submission set + cap counting for a group.
  @@index([assignmentId, problemId, studentGroupId])
  // Performance indexes
  @@index([assignmentId, problemId])
  @@index([studentId, courseId, assignmentId, problemId, submittedAt])
  // Hot path for the submission queue worker's claim query
  @@index([status, submittedAt])
  @@index([status])
}

model AssignmentProblemGrade {
  id       String  @id @default(cuid())
  grade    Float
  feedback String?

  // True when a staff member set this grade by hand. The autograder refuses to
  // overwrite a manually-graded row, so a later (or reran) evaluation can't clobber
  // a TA's grade.
  gradedManually Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignmentProblem AssignmentProblem @relation(fields: [assignmentId, problemId], references: [assignmentId, problemId], onDelete: Cascade, onUpdate: Cascade)
  assignmentId      String
  problemId         String

  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  @@unique([assignmentId, problemId, studentId])
  @@index([assignmentId, problemId])
  @@index([assignmentId])
  @@index([studentId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String

  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId String

  // The author is always a User. `roster` is only the author's role WITHIN this
  // course (for the role badge) and is null when the author isn't rostered (e.g. a
  // system admin commenting on a course they aren't enrolled in). We never fabricate a
  // roster row just to attribute a comment.
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  roster   Roster? @relation(fields: [rosterId], references: [id], onDelete: SetNull)
  rosterId String?

  aboutStudent   User?   @relation("CommentsAboutStudent", fields: [aboutStudentId], references: [id], onDelete: Cascade)
  aboutStudentId String?

  @@index([assignmentId])
  @@index([problemId])
  @@index([authorId])
  @@index([rosterId])
  @@index([aboutStudentId])
  @@index([assignmentId, problemId])
  @@index([assignmentId, problemId, aboutStudentId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  timestamp DateTime @default(now())
  metadata  Json?

  courseId     String?
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  problemId    String?
  problem      Problem?    @relation(fields: [problemId], references: [id], onDelete: SetNull)
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  // Additional categorization
  category  String? // SYSTEM, COURSE, ASSIGNMENT, PROBLEM, SUBMISSION, USER
  severity  LogSeverity @default(INFO)
  ipAddress String?
  userAgent String?

  // Index strategy for a high-write, admin-read log table. Composites serve
  // "filter by X, order by timestamp desc" in a single scan; single-column
  // indexes that are the leftmost prefix of a composite are omitted to keep
  // insert cost down (e.g. userId is covered by [userId, courseId]).
  @@index([timestamp]) // default System Logs ordering
  @@index([severity, timestamp]) // severity dropdown + timestamp sort
  @@index([action])
  @@index([category])
  @@index([problemId])
  @@index([submissionId])
  @@index([courseId, action])
  @@index([assignmentId, action])
  @@index([userId, courseId])
  @@index([timestamp, category])
}

model SystemSettings {
  /// Singleton row (id=1)
  id                    Int     @id @default(1)
  timezone              String  @default("UTC")
  maxUploadSizeMb       Int     @default(25)
  allowSignup           Boolean @default(true)
  // Canonical comma-separated allow-list of email domains permitted to self-register
  // (e.g. "psu.edu,example.edu"). Blank = no restriction (any domain may sign up).
  signupAllowedDomains  String  @default("")
  sessionTimeoutMinutes Int     @default(60)

  // App-wide date/time display preference. When true, times render on a 24-hour clock
  // (e.g. 23:59); otherwise 12-hour with AM/PM. Display-only, never affects stored
  // UTC instants or deadline enforcement.
  clock24Hour Boolean @default(false)

  // Login lockout policy (per-account): how many failed attempts before the
  // account is temporarily locked, and for how long.
  loginMaxAttempts    Int @default(10)
  loginLockoutMinutes Int @default(10)

  // Database backups (run by the db-backup container). backupHour is the
  // server-time (UTC) hour to run the daily dump; retention is days of dumps kept.
  backupEnabled       Boolean @default(true)
  backupHour          Int     @default(2)
  backupRetentionDays Int     @default(14)

  // How long to keep audit-log rows before the pruner deletes them.
  activityLogRetentionDays Int @default(365)

  // Submission queue tunables (time values stored in ms)
  submissionEvalTimeoutMs      Int @default(30000)
  submissionEvalMaxMemoryMb    Int @default(256)
  submissionResubmitCooldownMs Int @default(10000)
  submissionMaxConcurrent      Int @default(5)
  submissionMaxAttempts        Int @default(3)
  // Exploration bound passed to the cfganalyzer evaluator (CFGANALYZER_LIMIT).
  submissionAnalyzerLimit      Int @default(15)

  // hCaptcha keys (null = fall back to env, then disabled). Secret is never
  // returned to the client.
  hcaptchaSiteKey   String?
  hcaptchaSecretKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "ERD.svg"
  disabled = env("DISABLE_ERD")
}
