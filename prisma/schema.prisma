generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FACULTY
  TA
  STUDENT
}

enum CourseRole {
  INSTRUCTOR
  FACULTY
  TA
  STUDENT
}

enum ProblemType {
  PDA
  RE
  CFG
  FA
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  firstName String?
  lastName  String?
  password  String
  role      Role    @default(STUDENT) // Global role
  avatar    String?
  timezone  String?
  inactive  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rosterEntries Roster[] // Per-course memberships with roles
  submissions   Submission[]
  grades        AssignmentGrade[] // Grades for assignments
  activityLogs  ActivityLog[]
  groupRosters  GroupRoster[] // Group memberships across courses
  commentsAbout Comment[]         @relation("CommentsAboutStudent") // Comments about this student's work

  @@index([role])
  @@index([inactive])
  @@index([createdAt])
}

model Course {
  id          String   @id @default(cuid())
  name        String
  code        String
  regCode     String?  @unique
  semester    String
  credits     Int
  startDate   DateTime
  endDate     DateTime
  isPublished Boolean  @default(false)
  isArchived  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roster       Roster[] // Users in the course with roles
  assignments  Assignment[]
  problems     Problem[]
  groups       Group[]
  groupRosters GroupRoster[]
  activityLogs ActivityLog[]

  @@index([isPublished])
  @@index([createdAt])
}

model Roster {
  id   String     @id @default(cuid())
  role CourseRole // Role for the user in this course

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[] // Comments by this roster member

  @@unique([courseId, userId]) // Ensures one role per user per course
  @@index([courseId])
  @@index([userId])
  @@index([role])
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  maxPoints   Float
  isPublished Boolean  @default(false)
  isGroup     Boolean  @default(false) // Whether this assignment is group-based

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  problems     AssignmentProblem[]
  comments     Comment[]
  activityLogs ActivityLog[]
  grades       AssignmentGrade[] // Student grades for this assignment
  groupAssignmentProblems GroupAssignmentProblem[]

  @@index([courseId])
  @@index([isPublished])
  @@index([dueDate])
  @@index([courseId, isPublished])
  @@index([isGroup])
}

model Problem {
  id               String       @id @default(cuid())
  title            String
  description      String?
  fileName         String?
  originalFileName String?
  type             ProblemType?
  maxStates        Int?
  isDeterministic  Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  assignments  AssignmentProblem[]
  groupAssignmentProblems GroupAssignmentProblem[]
  comments     Comment[]
  activityLogs ActivityLog[]



  @@index([courseId])
  @@index([type])
  @@index([createdAt])
}

model Group {
  id   String @id @default(cuid())
  name String

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupRosters            GroupRoster[]
  submissions             Submission[]

  groupAssignmentProblems GroupAssignmentProblem[]

  @@unique([courseId, name])
  @@index([courseId])
}

model GroupRoster {
  id String @id @default(cuid())

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([groupId])
}

model AssignmentProblem {
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  problem      Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId    String

  submissions Submission[]

  @@id([assignmentId, problemId])
}

model GroupAssignmentProblem {
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  problem      Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId    String
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String

  @@id([assignmentId, problemId, groupId])
  @@index([groupId])
}



model Submission {
  id          String   @id @default(cuid())
  submittedAt DateTime @default(now())
  feedback    String?
  correct     Boolean?

  fileName         String?
  originalFileName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignmentProblem AssignmentProblem @relation(fields: [assignmentId, problemId], references: [assignmentId, problemId], onDelete: Cascade)
  assignmentId      String
  problemId         String

  // For individual submissions this is the submitting student
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  // Optional group reference for group submissions
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId String?

  activityLogs ActivityLog[]

  @@unique([assignmentId, problemId, groupId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([groupId])
  @@index([assignmentId, problemId, studentId])
}

model AssignmentGrade {
  id       String  @id @default(cuid())
  grade    Float
  feedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String

  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  @@unique([assignmentId, studentId]) // One grade per student per assignment
  @@index([assignmentId])
  @@index([studentId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String

  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId String

  roster   Roster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  rosterId String

  aboutStudent   User?   @relation("CommentsAboutStudent", fields: [aboutStudentId], references: [id], onDelete: Cascade)
  aboutStudentId String?

  @@index([assignmentId])
  @@index([problemId])
  @@index([rosterId])
  @@index([aboutStudentId])
  @@index([assignmentId, problemId])
  @@index([assignmentId, problemId, aboutStudentId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  timestamp DateTime @default(now())
  metadata  Json?

  // Normalized foreign keys for fast filtering
  courseId     String?
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  problemId    String?
  problem      Problem?    @relation(fields: [problemId], references: [id], onDelete: SetNull)
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  // Additional categorization
  category  String? // SYSTEM, COURSE, ASSIGNMENT, PROBLEM, SUBMISSION, USER
  ipAddress String?
  userAgent String?

  @@index([timestamp])
  @@index([userId])
  @@index([action])
  @@index([category])
  @@index([courseId])
  @@index([assignmentId])
  @@index([problemId])
  @@index([submissionId])
  @@index([courseId, action])
  @@index([assignmentId, action])
  @@index([userId, courseId])
  @@index([timestamp, category])
}

model SystemSettings {
  /// Singleton row (id=1)
  id              Int    @id @default(1)
  timezone        String @default("UTC")
  maxUploadSizeMb Int    @default(25)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "ERD.svg"
  // Only run locally when explicitly enabled
  disabled = env("DISABLE_ERD")
}
