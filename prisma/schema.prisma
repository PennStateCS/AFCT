generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseRole {
  FACULTY
  TA
  STUDENT
}

enum ProblemType {
  PDA
  RE
  CFG
  FA
  TM
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// How the empty string is rendered in automata/languages for a course.
enum EmptyStringNotation {
  EPSILON // ε
  LAMBDA // λ
}

// Severity/level of an audit-log entry.
enum LogSeverity {
  INFO // routine, successful activity
  WARNING // expected rejections / invalid input / non-fatal issues
  ERROR // system or operational failures
  SECURITY // auth failures and access-control denials
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  firstName String?
  lastName  String?
  password  String
  temporaryPassword Boolean @default(false)
  // Global system-admin grant. Course-level abilities live on Roster.role; this
  // flag is the only global privilege.
  isAdmin   Boolean @default(false)
  avatar    String?
  timezone  String?
  inactive  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rosterEntries Roster[]
  submissions   Submission[]
  problemGrades AssignmentProblemGrade[]
  activityLogs  ActivityLog[]
  groupRosters  GroupRoster[] // Group memberships across courses
  commentsAbout Comment[]         @relation("CommentsAboutStudent") // Comments about this student's work

  @@index([isAdmin])
  @@index([inactive])
  @@index([createdAt])
}

model Course {
  id          String   @id @default(cuid())
  name        String
  code        String
  regCode     String?  @unique
  semester    String
  credits     Int
  startDate   DateTime
  endDate     DateTime
  registrationOpenAt  DateTime?
  registrationCloseAt DateTime?
  isPublished Boolean  @default(false)
  isArchived  Boolean  @default(false)

  // How the empty string is displayed in automata/languages for this course.
  emptyStringNotation EmptyStringNotation @default(EPSILON)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roster       Roster[] // Users in the course with roles
  assignments  Assignment[]
  problems     Problem[]
  submissions   Submission[]
  groups       Group[]
  groupRosters GroupRoster[]
  activityLogs ActivityLog[]

  @@index([isPublished])
  @@index([createdAt])
  @@index([registrationOpenAt])
  @@index([registrationCloseAt])
}

model Roster {
  id   String     @id @default(cuid())
  role CourseRole

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([role])
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  isPublished Boolean  @default(false)
  isGroup     Boolean  @default(false) // Whether this assignment is group-based

  // Late submission controls
  allowLateSubmissions Boolean  @default(true)
  lateCutoff           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  problems     AssignmentProblem[]
  comments     Comment[]
  activityLogs ActivityLog[]
  groupAssignmentProblems GroupAssignmentProblem[]

  @@index([courseId])
  @@index([isPublished])
  @@index([dueDate])
  @@index([lateCutoff])
  @@index([courseId, isPublished])
  @@index([isGroup])
}

model Problem {
  id               String       @id @default(cuid())
  title            String
  description      String?
  fileName         String?
  originalFileName String?
  maxSubmissions   Int?
  maxPoints        Int         @default(100)
  autograderEnabled Boolean    @default(true)
  type             ProblemType?
  maxStates        Int?
  isDeterministic  Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  assignments  AssignmentProblem[]
  groupAssignmentProblems GroupAssignmentProblem[]
  comments     Comment[]
  activityLogs ActivityLog[]



  @@index([courseId])
  @@index([type])
  @@index([createdAt])
}

model Group {
  id   String @id @default(cuid())
  name String

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupRosters            GroupRoster[]
  submissions             Submission[]

  groupAssignmentProblems GroupAssignmentProblem[]

  @@unique([courseId, name])
  @@index([courseId])
}

model GroupRoster {
  id String @id @default(cuid())

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([groupId])
}

model AssignmentProblem {
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  problem      Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId    String

  // Per-assignment configuration
  maxPoints         Float   @default(0)
  maxSubmissions    Int     @default(1)
  autograderEnabled Boolean @default(true)

  submissions Submission[]
  grades      AssignmentProblemGrade[]

  @@id([assignmentId, problemId])
  @@index([assignmentId])
}

model GroupAssignmentProblem {
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  problem      Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId    String
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String

  @@id([assignmentId, problemId, groupId])
  @@index([groupId])
}



model Submission {
  id          String   @id @default(cuid())
  feedback    String?
  correct     Boolean?
  evaluationRaw Json?

  fileName         String?
  originalFileName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignmentProblem AssignmentProblem @relation(fields: [assignmentId, problemId], references: [assignmentId, problemId], onDelete: Cascade)

  assignmentId String
  problemId    String

  // For individual submissions this is the submitting student
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  // Course reference
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  // Optional group reference for group submissions
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId String?

  // Queue
  status   SubmissionStatus @default(PENDING)
  submittedAt DateTime         @default(now())
  attempts Int              @default(0) // Number of times the worker has claimed this submission

  // Logs
  activityLogs ActivityLog[]

  @@unique([assignmentId, problemId, groupId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([courseId])
  @@index([groupId])
  @@index([assignmentId, problemId, studentId])

  // Performance indexes
  @@index([assignmentId, problemId])
  @@index([studentId, courseId, assignmentId, problemId, submittedAt])
  // Hot path for the submission queue worker's claim query
  @@index([status, submittedAt])
  @@index([status])
}

model AssignmentProblemGrade {
  id       String  @id @default(cuid())
  grade    Float
  feedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignmentProblem AssignmentProblem @relation(fields: [assignmentId, problemId], references: [assignmentId, problemId], onDelete: Cascade, onUpdate: Cascade)
  assignmentId String
  problemId    String

  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  @@unique([assignmentId, problemId, studentId])
  @@index([assignmentId, problemId])
  @@index([assignmentId])
  @@index([studentId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String

  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId String

  roster   Roster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  rosterId String

  aboutStudent   User?   @relation("CommentsAboutStudent", fields: [aboutStudentId], references: [id], onDelete: Cascade)
  aboutStudentId String?

  @@index([assignmentId])
  @@index([problemId])
  @@index([rosterId])
  @@index([aboutStudentId])
  @@index([assignmentId, problemId])
  @@index([assignmentId, problemId, aboutStudentId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  timestamp DateTime @default(now())
  metadata  Json?

  courseId     String?
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  problemId    String?
  problem      Problem?    @relation(fields: [problemId], references: [id], onDelete: SetNull)
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  // Additional categorization
  category  String? // SYSTEM, COURSE, ASSIGNMENT, PROBLEM, SUBMISSION, USER
  severity  LogSeverity @default(INFO)
  ipAddress String?
  userAgent String?

  // Index strategy for a high-write, admin-read log table. Composites serve
  // "filter by X, order by timestamp desc" in a single scan; single-column
  // indexes that are the leftmost prefix of a composite are omitted to keep
  // insert cost down (e.g. userId is covered by [userId, courseId]).
  @@index([timestamp]) // default System Logs ordering
  @@index([severity, timestamp]) // severity dropdown + timestamp sort
  @@index([action])
  @@index([category])
  @@index([problemId])
  @@index([submissionId])
  @@index([courseId, action])
  @@index([assignmentId, action])
  @@index([userId, courseId])
  @@index([timestamp, category])
}

model SystemSettings {
  /// Singleton row (id=1)
  id              Int    @id @default(1)
  timezone        String @default("UTC")
  maxUploadSizeMb Int    @default(25)
  allowSignup     Boolean @default(true)
  sessionTimeoutMinutes Int @default(60)

  // Login lockout policy (per-account): how many failed attempts before the
  // account is temporarily locked, and for how long.
  loginMaxAttempts    Int @default(10)
  loginLockoutMinutes Int @default(45)

  // Database backups (run by the db-backup container). backupHour is the
  // server-time (UTC) hour to run the daily dump; retention is days of dumps kept.
  backupEnabled       Boolean @default(true)
  backupHour          Int     @default(2)
  backupRetentionDays Int     @default(14)

  // How long to keep audit-log rows before the pruner deletes them.
  activityLogRetentionDays Int @default(365)

  // Submission queue tunables (time values stored in ms)
  submissionEvalTimeoutMs      Int @default(30000)
  submissionEvalMaxMemoryMb    Int @default(256)
  submissionResubmitCooldownMs Int @default(10000)
  submissionMaxConcurrent      Int @default(5)
  submissionMaxAttempts        Int @default(3)
  // Exploration bound passed to the cfganalyzer evaluator (CFGANALYZER_LIMIT).
  submissionAnalyzerLimit      Int @default(15)

  // hCaptcha keys (null = fall back to env, then disabled). Secret is never
  // returned to the client.
  hcaptchaSiteKey   String?
  hcaptchaSecretKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "ERD.svg"
  disabled = env("DISABLE_ERD")
}
